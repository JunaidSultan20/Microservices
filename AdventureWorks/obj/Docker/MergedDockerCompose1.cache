name: dockercompose4656335781798388365
services:
  adventureworks.gateway.api:
    build:
      context: D:\Projects\AdventureWorks
      dockerfile: AdventureWorks.Gateway.API/Dockerfile
      labels:
        com.microsoft.created-by: visual-studio
        com.microsoft.visual-studio.project-name: AdventureWorks.Gateway.API
      target: base
    container_name: gateway.api
    depends_on:
      adventureworks.sales.api:
        condition: service_started
    entrypoint:
    - tail
    - -f
    - /dev/null
    environment:
      ASPNETCORE_ENVIRONMENT: Development
      ASPNETCORE_LOGGING__CONSOLE__DISABLECOLORS: "true"
      ASPNETCORE_URLS: https://0.0.0.0:443;http://0.0.0.0:80
      DOTNET_USE_POLLING_FILE_WATCHER: "1"
      NUGET_FALLBACK_PACKAGES: ""
    hostname: gateway.api
    image: adventureworksgatewayapi:dev
    labels:
      com.microsoft.visualstudio.debuggee.arguments: ' --additionalProbingPath /root/.nuget/packages  "/app/bin/Debug/net6.0/AdventureWorks.Gateway.API.dll"'
      com.microsoft.visualstudio.debuggee.killprogram: /bin/sh -c "if PID=$$(pidof
        dotnet); then kill $$PID; fi"
      com.microsoft.visualstudio.debuggee.program: dotnet
      com.microsoft.visualstudio.debuggee.workingdirectory: /app
    networks:
      adventureworksnetwork:
        ipv4_address: 172.10.0.4
    ports:
    - mode: ingress
      target: 80
      published: "5001"
      protocol: tcp
    - mode: ingress
      target: 443
      published: "5000"
      protocol: tcp
    restart: on-failure
    tty: true
    volumes:
    - type: bind
      source: D:\Projects\AdventureWorks\AdventureWorks.Gateway.API
      target: /app
      bind:
        create_host_path: true
    - type: bind
      source: C:\Users\Junaid Sultan\vsdbg\vs2017u5
      target: /remote_debugger
      bind:
        create_host_path: true
    - type: bind
      source: C:\Users\Junaid Sultan\AppData\Roaming/ASP.NET/Https
      target: /root/.aspnet/https
      read_only: true
      bind:
        create_host_path: true
    - type: bind
      source: C:\Users\Junaid Sultan\AppData\Roaming/Microsoft/UserSecrets
      target: /root/.microsoft/usersecrets
      read_only: true
      bind:
        create_host_path: true
    - type: bind
      source: C:\Users\Junaid Sultan\.nuget\packages\
      target: /root/.nuget/packages
      read_only: true
      bind:
        create_host_path: true
    - type: bind
      source: D:\Projects\AdventureWorks
      target: /src
      bind:
        create_host_path: true
  adventureworks.sales.api:
    build:
      context: D:\Projects\AdventureWorks
      dockerfile: AdventureWorks.Sales.API/Dockerfile
      labels:
        com.microsoft.created-by: visual-studio
        com.microsoft.visual-studio.project-name: AdventureWorks.Sales.API
      target: base
    container_name: sales.api
    depends_on:
      adventureworksredis:
        condition: service_started
      consul:
        condition: service_started
    entrypoint:
    - tail
    - -f
    - /dev/null
    environment:
      ASPNETCORE_ENVIRONMENT: Development
      ASPNETCORE_LOGGING__CONSOLE__DISABLECOLORS: "true"
      ASPNETCORE_URLS: https://0.0.0.0:443;http://0.0.0.0:80
      DOTNET_USE_POLLING_FILE_WATCHER: "1"
      NUGET_FALLBACK_PACKAGES: ""
    hostname: https://localhost
    image: adventureworkssalesapi:dev
    labels:
      com.microsoft.visualstudio.debuggee.arguments: ' --additionalProbingPath /root/.nuget/packages  "/app/bin/Debug/net6.0/AdventureWorks.Sales.API.dll"'
      com.microsoft.visualstudio.debuggee.killprogram: /bin/sh -c "if PID=$$(pidof
        dotnet); then kill $$PID; fi"
      com.microsoft.visualstudio.debuggee.program: dotnet
      com.microsoft.visualstudio.debuggee.workingdirectory: /app
    networks:
      adventureworksnetwork:
        ipv4_address: 172.10.0.5
    ports:
    - mode: ingress
      target: 80
      published: "4001"
      protocol: tcp
    - mode: ingress
      target: 443
      published: "4000"
      protocol: tcp
    restart: on-failure
    tty: true
    volumes:
    - type: bind
      source: D:\Projects\AdventureWorks\AdventureWorks.Sales.API
      target: /app
      bind:
        create_host_path: true
    - type: bind
      source: C:\Users\Junaid Sultan\vsdbg\vs2017u5
      target: /remote_debugger
      bind:
        create_host_path: true
    - type: bind
      source: C:\Users\Junaid Sultan\AppData\Roaming/ASP.NET/Https
      target: /root/.aspnet/https
      read_only: true
      bind:
        create_host_path: true
    - type: bind
      source: C:\Users\Junaid Sultan\AppData\Roaming/Microsoft/UserSecrets
      target: /root/.microsoft/usersecrets
      read_only: true
      bind:
        create_host_path: true
    - type: bind
      source: C:\Users\Junaid Sultan\.nuget\packages\
      target: /root/.nuget/packages
      read_only: true
      bind:
        create_host_path: true
    - type: bind
      source: D:\Projects\AdventureWorks
      target: /src
      bind:
        create_host_path: true
  adventureworksredis:
    container_name: adventureworksredis
    expose:
    - "6379"
    image: redis:latest
    networks:
      adventureworksnetwork:
        ipv4_address: 172.10.0.2
    ports:
    - mode: ingress
      target: 6379
      published: "6379"
      protocol: tcp
  consul:
    command:
    - consul
    - agent
    - -dev
    - -log-level=warn
    - -ui
    - -client=0.0.0.0
    container_name: consul
    expose:
    - "8500"
    hostname: consul
    image: consul:latest
    networks:
      adventureworksnetwork:
        ipv4_address: 172.10.0.3
    ports:
    - mode: ingress
      target: 8500
      published: "8500"
      protocol: tcp
networks:
  adventureworksnetwork:
    name: dockercompose4656335781798388365_adventureworksnetwork
    driver: bridge
    ipam:
      driver: default
      config:
      - subnet: 172.10.0.0/16
        gateway: 172.10.0.1