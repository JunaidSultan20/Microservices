networks:
  adventureworksnetwork:
    driver: bridge
    ipam:
      config:
      - gateway: 172.10.0.1
        subnet: 172.10.0.0/16
      driver: default
services:
  adventureworks.gateway.api:
    build:
      context: D:\AdventureWorks
      dockerfile: AdventureWorks.Gateway.API/Dockerfile
    container_name: gateway.api
    depends_on:
      adventureworks.sales.api:
        condition: service_started
    environment:
      ASPNETCORE_ENVIRONMENT: Development
      ASPNETCORE_URLS: https://0.0.0.0:443;http://0.0.0.0:80
    hostname: gateway.api
    image: adventureworksgatewayapi
    networks:
      adventureworksnetwork:
        ipv4_address: 172.10.0.4
    ports:
    - published: 5001
      target: 80
    - published: 5000
      target: 443
    restart: on-failure
    volumes:
    - C:\Users\junaid.sultan\AppData\Roaming\ASP.NET\Https:/root/.aspnet/https:ro
    - C:\Users\junaid.sultan\AppData\Roaming\Microsoft\UserSecrets:/root/.microsoft/usersecrets:ro
  adventureworks.sales.api:
    build:
      context: D:\AdventureWorks
      dockerfile: AdventureWorks.Sales.API/Dockerfile
    container_name: sales.api
    depends_on:
      adventureworksredis:
        condition: service_started
      consul:
        condition: service_started
    environment:
      ASPNETCORE_ENVIRONMENT: Development
      ASPNETCORE_URLS: https://0.0.0.0:443;http://0.0.0.0:80
    hostname: https://localhost
    image: adventureworkssalesapi
    networks:
      adventureworksnetwork:
        ipv4_address: 172.10.0.5
    ports:
    - published: 4001
      target: 80
    - published: 4000
      target: 443
    restart: on-failure
    volumes:
    - C:\Users\junaid.sultan\AppData\Roaming\ASP.NET\Https:/root/.aspnet/https:ro
    - C:\Users\junaid.sultan\AppData\Roaming\Microsoft\UserSecrets:/root/.microsoft/usersecrets:ro
  adventureworksredis:
    container_name: adventureworksredis
    expose:
    - '6379'
    image: redis:latest
    networks:
      adventureworksnetwork:
        ipv4_address: 172.10.0.2
    ports:
    - published: 6379
      target: 6379
  consul:
    command: consul agent -dev -log-level=warn -ui -client=0.0.0.0
    container_name: consul
    expose:
    - '8500'
    hostname: consul
    image: consul:latest
    networks:
      adventureworksnetwork:
        ipv4_address: 172.10.0.3
    ports:
    - published: 8500
      target: 8500
version: '3.9'