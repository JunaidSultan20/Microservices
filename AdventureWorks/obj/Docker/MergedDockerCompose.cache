name: dockercompose4656335781798388365
services:
  adventureworks.gateway.api:
    build:
      context: D:\Projects\AdventureWorks
      dockerfile: AdventureWorks.Gateway.API/Dockerfile
    container_name: gateway.api
    depends_on:
      adventureworks.sales.api:
        condition: service_started
    environment:
      ASPNETCORE_ENVIRONMENT: Development
      ASPNETCORE_URLS: https://0.0.0.0:443;http://0.0.0.0:80
    hostname: gateway.api
    image: adventureworksgatewayapi
    networks:
      adventureworksnetwork:
        ipv4_address: 172.10.0.4
    ports:
    - mode: ingress
      target: 80
      published: "5001"
      protocol: tcp
    - mode: ingress
      target: 443
      published: "5000"
      protocol: tcp
    restart: on-failure
    volumes:
    - type: bind
      source: C:\Users\Junaid Sultan\AppData\Roaming/Microsoft/UserSecrets
      target: /root/.microsoft/usersecrets
      read_only: true
      bind:
        create_host_path: true
    - type: bind
      source: C:\Users\Junaid Sultan\AppData\Roaming/ASP.NET/Https
      target: /root/.aspnet/https
      read_only: true
      bind:
        create_host_path: true
  adventureworks.sales.api:
    build:
      context: D:\Projects\AdventureWorks
      dockerfile: AdventureWorks.Sales.API/Dockerfile
    container_name: sales.api
    depends_on:
      adventureworksredis:
        condition: service_started
      consul:
        condition: service_started
    environment:
      ASPNETCORE_ENVIRONMENT: Development
      ASPNETCORE_URLS: https://0.0.0.0:443;http://0.0.0.0:80
    hostname: https://localhost
    image: adventureworkssalesapi
    networks:
      adventureworksnetwork:
        ipv4_address: 172.10.0.5
    ports:
    - mode: ingress
      target: 80
      published: "4001"
      protocol: tcp
    - mode: ingress
      target: 443
      published: "4000"
      protocol: tcp
    restart: on-failure
    volumes:
    - type: bind
      source: C:\Users\Junaid Sultan\AppData\Roaming/Microsoft/UserSecrets
      target: /root/.microsoft/usersecrets
      read_only: true
      bind:
        create_host_path: true
    - type: bind
      source: C:\Users\Junaid Sultan\AppData\Roaming/ASP.NET/Https
      target: /root/.aspnet/https
      read_only: true
      bind:
        create_host_path: true
  adventureworksredis:
    container_name: adventureworksredis
    expose:
    - "6379"
    image: redis:latest
    networks:
      adventureworksnetwork:
        ipv4_address: 172.10.0.2
    ports:
    - mode: ingress
      target: 6379
      published: "6379"
      protocol: tcp
  consul:
    command:
    - consul
    - agent
    - -dev
    - -log-level=warn
    - -ui
    - -client=0.0.0.0
    container_name: consul
    expose:
    - "8500"
    hostname: consul
    image: consul:latest
    networks:
      adventureworksnetwork:
        ipv4_address: 172.10.0.3
    ports:
    - mode: ingress
      target: 8500
      published: "8500"
      protocol: tcp
networks:
  adventureworksnetwork:
    name: dockercompose4656335781798388365_adventureworksnetwork
    driver: bridge
    ipam:
      driver: default
      config:
      - subnet: 172.10.0.0/16
        gateway: 172.10.0.1